@{
    ViewBag.Title = "Trang Chủ";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

@model IEnumerable<ProTechTiveGear.Models.Item>

<style>
    /* CSS bổ sung để làm đẹp card sản phẩm */
    .cake_feature_item {
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.4s ease;
        margin-bottom: 30px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        border: 1px solid #f0f0f0;
    }

    .cake_feature_item:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1);
    }

    .cake_img {
        overflow: hidden;
        position: relative;
    }

    .cake_img img {
        width: 100%;
        height: 250px; /* Cố định chiều cao để đều hàng */
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .cake_feature_item:hover .cake_img img {
        transform: scale(1.1);
    }

    .cake_text {
        padding: 20px !important;
        background-color: #fff !important; /* Loại bỏ màu xanh cũ */
        text-align: center;
    }

    .cake_text h3 {
        font-size: 16px;
        font-weight: 600;
        color: #2c3e50;
        margin: 10px 0;
        height: 40px; /* Đảm bảo tên dài không làm lệch hàng */
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .cake_text h4 {
        color: #e67e22; /* Màu cam giá tiền */
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 15px;
    }

    .pest_btn {
        display: inline-block;
        padding: 10px 20px;
        border-radius: 25px;
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        transition: 0.3s;
        border: none;
        width: 100%;
    }

    .pest_btn:not(.disabled) {
        background-color: #2c3e50 !important;
        color: #fff !important;
    }

    .pest_btn:not(.disabled):hover {
        background-color: #e67e22 !important;
    }

    .pest_btn.disabled {
        background-color: #ccc !important;
        cursor: not-allowed;
        color: #fff !important;
    }

    /* Section Title */
    .main_title h2 {
        position: relative;
        font-weight: 700;
        padding-bottom: 15px;
        margin-bottom: 40px;
    }

    .main_title h2:after {
        content: '';
        width: 60px;
        height: 3px;
        background: #e67e22;
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
    }

    /* CSS cho Mini Banners */
    .mini_banners_area {
        padding-top: 30px;
        padding-bottom: 0px;
    }

    .mini_banner_item {
        overflow: hidden;
        border-radius: 10px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        transition: all 0.3s ease;
        margin-bottom: 20px;
    }

    .mini_banner_item:hover {
        transform: scale(1.03);
        box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    }

    .mini_banner_item img {
        width: 100%;
        height: 180px; /* Chiều cao cố định cho các banner nhỏ */
        object-fit: cover; /* Đảm bảo ảnh không bị méo */
        display: block;
    }
</style>

<section class="mini_banners_area">
    <div class="container">
        <div class="row">
            <div class="col-md-6 col-sm-12">
                <div class="mini_banner_item">
                    <a href="#">
                        <img src="https://hqcomputer.com/assets/uploads/banner-2.jpg" alt="Quảng cáo 1">
                    </a>
                </div>
            </div>
            <div class="col-md-6 col-sm-12">
                <div class="mini_banner_item">
                    <a href="#">
                        <img src="https://maytinhbaclieu.com.vn/wp-content/uploads/2020/05/b1.jpg" alt="Quảng cáo 2">
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
<section class="welcome_bakery_area cake_feature_main p_100">
    <div class="container">
        <div class="main_title">
            <h2>Sản phẩm Nổi bật</h2>
        </div>

        <div class="cake_feature_row row">
            @foreach (var item in Model)
            {
                <div class="col-lg-3 col-md-4 col-6">
                    <div class="cake_feature_item">
                        <a href="@Url.Action("Detail","AuraStore",new { id=item.ID})">
                            <div class="cake_img">
                                @if (item.Quantity == 0)
                                {
                                    <div class="stock-label" style="position:absolute; top:10px; right:10px; background:rgba(255,0,0,0.8); color:#fff; padding:2px 10px; border-radius:15px; font-size:11px; z-index:1;">Hết hàng</div>
                                }
                                <img src="~/img/Item/@item.Picture" alt="@item.Name">
                            </div>
                        </a>
                        <div class="cake_text">
                            <h4>@String.Format("{0:0,0}", item.SellPrice) VNĐ</h4>
                            <h3>@item.Name</h3>
                            
                            @if (item.Quantity == 0)
                            {
                                <a class="pest_btn disabled">Hết hàng</a>
                            }
                            else
                            {
                                <a class="pest_btn" href="@Url.Action("AddtoCart","Cart",new {@id=item.ID, @strURL=Request.Url.ToString() })">
                                    <i class="fa fa-shopping-cart"></i> Thêm vào giỏ
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section class="new_arivals_area p_100" style="background-color:#f9f9f9">
    <div class="container">
        <div class="single_pest_title">
            <h2 style="font-weight:700; margin-bottom: 40px;">Hàng mới cập nhật</h2>
        </div>

        <div class="row arivals_inner">
            <div class="col-lg-6 col-sm-12">
                <div class="arivals_chocolate shadow-sm" style="border-radius:15px; overflow:hidden; background:#fff; margin-bottom:30px;">
                    <div class="arivals_pic">
                        <img class="img-fluid" src="https://nguyencongpc.vn/media/banner/02_Marf9f16aa84348d219e9f0d7524d06e6d6.jpg" alt="Ram Pioneer" style="width:100%; height:350px; object-fit:contain;">
                      
                    </div>
                
                 
                </div>
            </div>
            
            <div class="col-lg-6 col-sm-12">
                @Html.Action("Newdproducts", "AuraStore")
            </div>
        </div>
    </div>
</section>